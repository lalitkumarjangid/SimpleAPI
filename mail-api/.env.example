MAIL_API_PORT=3000
MAIL_API_KEY=change-me-to-a-long-random-secret
MAIL_MAX_BATCH=50
MAIL_CONCURRENCY=3
MAIL_CHECK_TIMEOUT_MS=45000

# Reacher only — no custom SMTP fallback (required)
REACHER_URL=http://localhost:8080

# SOCKS5 proxy for SMTP (optional — changes verification IP)
# REACHER_PROXY_HOST=your-proxy-host.com
# REACHER_PROXY_PORT=1080
# REACHER_PROXY_USERNAME=
# REACHER_PROXY_PASSWORD=
